---
import Base from '../layouts/Base.astro';
import MapEmbed from '../components/MapEmbed.astro';
---

<Base
  title="Contact TRS Pharmacy | Stafford, TX — Call 346-230-4148"
  description="Contact TRS Pharmacy in Stafford, TX. Call 346-230-4148, email info@trspharmacy.org, or visit us at 3727 Greenbriar Dr, Suite 114. Open Mon–Sat 9 AM–5 PM."
>
  <section class="bg-[#0F3460] text-white py-16">
    <div class="container-site">
      <h1 class="text-4xl font-extrabold mb-3">Contact TRS Pharmacy</h1>
      <p class="text-white/80 text-lg">We're here to help. Call, email, or stop by — Mon–Sat 9 AM to 5 PM.</p>
    </div>
  </section>

  <section class="container-site py-20">
    <div class="grid md:grid-cols-2 gap-12">
      <!-- Contact Info -->
      <div class="space-y-6">
        <div class="bg-white rounded-2xl border border-gray-200 p-6 shadow-sm">
          <p class="font-bold text-[#0F3460] text-lg mb-4">Get In Touch</p>
          <div class="flex flex-col gap-4 text-sm">
            <div class="flex items-start gap-4">
              <div class="w-9 h-9 bg-[#17A2B8]/10 rounded-lg flex items-center justify-center shrink-0">
                <svg class="w-4 h-4 text-[#17A2B8]" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" /></svg>
              </div>
              <div>
                <p class="text-[#64748B] text-xs uppercase tracking-wide font-semibold mb-1">Phone</p>
                <a href="tel:3462304148" class="font-bold text-[#17A2B8] text-base hover:underline">346-230-4148</a>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div class="w-9 h-9 bg-[#17A2B8]/10 rounded-lg flex items-center justify-center shrink-0">
                <svg class="w-4 h-4 text-[#17A2B8]" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" /></svg>
              </div>
              <div>
                <p class="text-[#64748B] text-xs uppercase tracking-wide font-semibold mb-1">Email</p>
                <a href="mailto:info@trspharmacy.org" class="font-bold text-[#17A2B8] hover:underline">info@trspharmacy.org</a>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div class="w-9 h-9 bg-[#17A2B8]/10 rounded-lg flex items-center justify-center shrink-0">
                <svg class="w-4 h-4 text-[#17A2B8]" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" /></svg>
              </div>
              <div>
                <p class="text-[#64748B] text-xs uppercase tracking-wide font-semibold mb-1">Address</p>
                <address class="not-italic text-[#1E293B] font-medium">
                  3727 Greenbriar Dr, Suite 114<br>
                  Stafford, TX 77477
                </address>
                <a href="https://maps.google.com/?q=3727+Greenbriar+Dr+Suite+114+Stafford+TX+77477" target="_blank" rel="noopener noreferrer" class="text-[#17A2B8] text-xs font-semibold hover:underline mt-1 inline-block">Get directions →</a>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div class="w-9 h-9 bg-[#17A2B8]/10 rounded-lg flex items-center justify-center shrink-0">
                <svg class="w-4 h-4 text-[#17A2B8]" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
              </div>
              <div>
                <p class="text-[#64748B] text-xs uppercase tracking-wide font-semibold mb-1">Hours</p>
                <p class="text-[#1E293B] font-medium">Mon – Sat: 9:00 AM – 5:00 PM</p>
                <p class="text-[#64748B] text-xs">Sunday: Closed</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Fax -->
        <div class="bg-[#F8FAFC] rounded-xl border border-gray-200 px-5 py-3 text-sm text-[#64748B]">
          Fax: 346-219-0414
        </div>

        <!-- Quick links -->
        <div class="bg-white rounded-2xl border border-gray-200 p-6 shadow-sm">
          <p class="font-bold text-[#0F3460] mb-3">Quick Actions</p>
          <div class="flex flex-col gap-2">
            <a href="/services/prescription-refills" class="text-[#17A2B8] font-semibold text-sm hover:underline">Refill or Transfer a Prescription →</a>
            <a href="/services/prescription-delivery" class="text-[#17A2B8] font-semibold text-sm hover:underline">Request Free Delivery →</a>
            <a href="/insurance-accepted" class="text-[#17A2B8] font-semibold text-sm hover:underline">Check Insurance Accepted →</a>
          </div>
        </div>
      </div>

      <!-- Map -->
      <div>
        <MapEmbed class="h-full min-h-[400px]" />
      </div>
    </div>
  </section>
</Base>
