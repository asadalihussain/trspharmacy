---
import Base from '../layouts/Base.astro';
import CTABanner from '../components/CTABanner.astro';

const reviews = [
  { quote: "TRS Pharmacy has been a lifesaver for our family. They work with our insurance AND helped us when we didn't have coverage. Truly a community gem.", name: 'Maria G.', location: 'Stafford, TX', rating: 5 },
  { quote: "I transferred my 6 prescriptions in one call. The team is so knowledgeable — Dr. Waseem actually called me about a potential drug interaction. That never happens at a chain pharmacy.", name: 'James T.', location: 'Missouri City, TX', rating: 5 },
  { quote: "Free delivery, great prices, and they actually pick up the phone. I've been coming here for 2 years and won't go anywhere else.", name: 'Fatima A.', location: 'Sugar Land, TX', rating: 5 },
  { quote: "As someone without insurance, I was dreading the cost of my medications. TRS found me a price I could actually afford. I'm genuinely grateful this pharmacy exists.", name: 'Robert M.', location: 'Stafford, TX', rating: 5 },
  { quote: "Got my flu shot and COVID booster at the same visit. No appointment needed, in and out in 15 minutes. Fantastic service.", name: 'Linda K.', location: 'SW Houston, TX', rating: 5 },
  { quote: "The pharmacogenomics consultation changed everything for me. We found out I was on a medication that my body couldn't properly metabolize. Switching made a huge difference.", name: 'David S.', location: 'Missouri City, TX', rating: 5 },
];
---

<Base
  title="Patient Reviews | TRS Pharmacy Stafford, TX"
  description="Read patient reviews for TRS Pharmacy in Stafford, TX. See what patients from Stafford, Sugar Land, and Missouri City say about our nonprofit community pharmacy."
>
  <section class="bg-[#0F3460] text-white py-16">
    <div class="container-site">
      <h1 class="text-4xl font-extrabold mb-3">Patient Reviews</h1>
      <p class="text-white/80 text-lg">What our patients say about TRS Pharmacy in Stafford, TX.</p>
    </div>
  </section>

  <section class="container-site py-20">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {reviews.map(r => (
        <div class="bg-white rounded-2xl p-6 border border-gray-200 shadow-sm flex flex-col">
          <div class="flex mb-3">
            {[1,2,3,4,5].map(_ => (
              <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            ))}
          </div>
          <p class="text-[#1E293B] italic flex-1 mb-4">"{r.quote}"</p>
          <div>
            <p class="font-semibold text-[#0F3460] text-sm">{r.name}</p>
            <p class="text-[#64748B] text-xs">{r.location}</p>
          </div>
        </div>
      ))}
    </div>
    <div class="mt-14 bg-[#F8FAFC] border border-gray-200 rounded-2xl p-8 text-center max-w-xl mx-auto">
      <p class="font-bold text-[#0F3460] text-lg mb-2">Had a great experience?</p>
      <p class="text-[#64748B] text-sm mb-5">We'd love to hear from you. Leave us a Google review — it helps other patients in Stafford find affordable pharmacy care.</p>
      <a href="https://g.page/r/review" target="_blank" rel="noopener noreferrer" class="btn-primary justify-center">Leave a Google Review</a>
    </div>
  </section>

  <CTABanner />
</Base>
