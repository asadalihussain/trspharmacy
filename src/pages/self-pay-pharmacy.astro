---
import Base from '../layouts/Base.astro';
import CTABanner from '../components/CTABanner.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "How much do prescriptions cost without insurance at TRS Pharmacy?", "acceptedAnswer": { "@type": "Answer", "text": "TRS Pharmacy offers self-pay prescriptions at cost plus a small dispensing fee — one of the lowest prices in the Stafford, TX area. We actively search for the best available pricing on your behalf." } },
    { "@type": "Question", "name": "Does TRS Pharmacy help uninsured patients?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. As a 501(c)(3) nonprofit, TRS Pharmacy is committed to serving uninsured patients. We find the best price available and offer cost-plus pricing to minimize your out-of-pocket costs." } },
  ]
};
---

<Base
  title="Self-Pay Pharmacy Stafford TX — Best Prescription Prices | TRS Pharmacy"
  description="No insurance? TRS Pharmacy in Stafford, TX offers the best self-pay prescription pricing — cost plus a small dispensing fee. We find you the lowest price. Serving Stafford, Sugar Land, Missouri City. Call 346-230-4148."
  schema={schema}
>
  <section class="bg-[#0F3460] text-white py-16">
    <div class="container-site">
      <h1 class="text-4xl md:text-5xl font-extrabold mb-4">No Insurance?<br>We Find You the Best Price.</h1>
      <p class="text-white/80 text-lg max-w-2xl">TRS Pharmacy is a 501(c)(3) nonprofit. For uninsured and self-pay patients, we offer prescriptions at our acquisition cost plus a small dispensing fee — and we actively search for the lowest price on your behalf.</p>
      <div class="mt-8 flex flex-wrap gap-4">
        <a href="tel:3462304148" class="btn-primary">Call for a Price Quote</a>
        <a href="/insurance-accepted" class="btn-outline">Check Insurance Instead</a>
      </div>
    </div>
  </section>

  <section class="container-site py-20">
    <div class="grid md:grid-cols-2 gap-16">
      <div>
        <h2 class="section-title">Our Self-Pay Pricing Model</h2>
        <p class="text-[#64748B] leading-relaxed mb-6">Most pharmacies mark up medication prices significantly. As a nonprofit, TRS Pharmacy operates differently: we pass our acquisition cost through to you, adding only a small dispensing fee to cover our operating costs.</p>
        <p class="text-[#64748B] leading-relaxed mb-6">In practice, this means your prescriptions often cost significantly less at TRS than at large chain pharmacies — even with their discount programs.</p>

        <h3 class="text-xl font-bold text-[#0F3460] mb-4">What We Do for Self-Pay Patients</h3>
        <ul class="space-y-4">
          {[
            ['Price Search', 'We check all available pricing sources to find the absolute lowest cost for your specific medication.'],
            ['Manufacturer Coupons', 'We apply manufacturer assistance programs and coupons when available.'],
            ['Generic Substitutions', 'We proactively suggest FDA-approved generic alternatives when they exist and are appropriate.'],
            ['Payment Flexibility', 'We work with you — because your health shouldn\'t depend on your income.'],
          ].map(([title, body]) => (
            <li class="flex gap-4">
              <span class="mt-1 w-5 h-5 bg-[#17A2B8]/10 rounded-full flex items-center justify-center shrink-0">
                <svg class="w-3 h-3 text-[#17A2B8]" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 00-1.414 0L8 12.586 4.707 9.293a1 1 0 00-1.414 1.414l4 4a1 1 0 001.414 0l8-8a1 1 0 000-1.414z" clip-rule="evenodd"/></svg>
              </span>
              <div>
                <p class="font-semibold text-[#0F3460]">{title}</p>
                <p class="text-sm text-[#64748B]">{body}</p>
              </div>
            </li>
          ))}
        </ul>
      </div>
      <div class="space-y-6">
        <div class="bg-[#F8FAFC] rounded-2xl border border-gray-200 p-6">
          <h3 class="font-bold text-[#0F3460] mb-3">Why TRS for Self-Pay?</h3>
          <ul class="space-y-3 text-sm text-[#64748B]">
            {[
              'Nonprofit mission — profit is never the priority',
              'Direct acquisition cost pricing',
              'Active price searching on your behalf',
              'Free delivery for 3+ prescriptions',
              'No membership fees or sign-up required',
            ].map(i => (
              <li class="flex gap-3">
                <svg class="w-4 h-4 text-[#17A2B8] mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                {i}
              </li>
            ))}
          </ul>
        </div>
        <div class="bg-white rounded-2xl border border-gray-200 p-6 shadow-sm">
          <p class="font-bold text-[#0F3460] mb-2">Get a Price Quote</p>
          <p class="text-sm text-[#64748B] mb-4">Call us with your medication name and we'll give you a price before you come in — no commitment required.</p>
          <a href="tel:3462304148" class="btn-primary justify-center text-center w-full block text-center">Call 346-230-4148</a>
        </div>
        <div class="bg-[#F8FAFC] rounded-xl border border-gray-200 px-5 py-4 text-sm text-[#64748B]">
          <strong class="text-[#0F3460] block mb-1">Precision Medicine Pricing</strong>
          Pharmacogenomics (PGx) testing for uninsured patients: $150–$300. Includes collection, testing, interpretation, consultation, and lifetime updates.
          <a href="/services/precision-medicine" class="text-[#17A2B8] font-semibold ml-1 hover:underline">Learn more →</a>
        </div>
      </div>
    </div>
  </section>

  <CTABanner
    heading="Affordable Prescriptions in Stafford, TX"
    subtext="Call TRS Pharmacy for a price quote before you come in. No insurance required. We serve patients across Stafford, Sugar Land, Missouri City, and SW Houston."
  />
</Base>
