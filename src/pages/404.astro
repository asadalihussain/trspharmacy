---
import Base from '../layouts/Base.astro';
---

<Base title="Page Not Found | TRS Pharmacy" description="The page you are looking for could not be found.">
  <section class="container-site py-32 text-center">
    <p class="text-[#17A2B8] font-bold text-6xl mb-4">404</p>
    <h1 class="text-3xl font-extrabold text-[#0F3460] mb-4">Page Not Found</h1>
    <p class="text-[#64748B] mb-8">The page you're looking for doesn't exist or has moved.</p>
    <div class="flex flex-wrap justify-center gap-4">
      <a href="/" class="btn-primary">Go Home</a>
      <a href="/services" class="btn-outline !border-[#17A2B8] !text-[#17A2B8] hover:!bg-[#17A2B8] hover:!text-white">View Services</a>
      <a href="/contact" class="btn-outline !border-[#17A2B8] !text-[#17A2B8] hover:!bg-[#17A2B8] hover:!text-white">Contact Us</a>
    </div>
  </section>
</Base>
