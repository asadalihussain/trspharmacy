---
import Base from '../../layouts/Base.astro';
import CTABanner from '../../components/CTABanner.astro';
import InsuranceGrid from '../../components/InsuranceGrid.astro';

const vaccines = [
  'COVID-19', 'Flu (Influenza)', 'Shingles (Shingrix)', 'Hepatitis A',
  'Hepatitis B', 'HPV (Gardasil)', 'MMR (Measles, Mumps, Rubella)',
  'Meningococcal', 'Pneumococcal', 'Tdap / Td', 'Travel Vaccines (various)',
];

const schema = {
  "@context": "https://schema.org",
  "@type": "MedicalProcedure",
  "name": "Immunizations and Vaccines",
  "description": "Vaccine administration services at TRS Pharmacy in Stafford, TX — flu, COVID, shingles, travel vaccines, and more.",
  "performedBy": { "@type": "Pharmacy", "name": "TRS Pharmacy" },
  "location": {
    "@type": "PostalAddress",
    "streetAddress": "3727 Greenbriar Dr, Suite 114",
    "addressLocality": "Stafford",
    "addressRegion": "TX",
    "postalCode": "77477"
  }
};
---

<Base
  title="Immunizations & Vaccines in Stafford, TX | TRS Pharmacy"
  description="TRS Pharmacy in Stafford, TX offers flu shots, COVID vaccines, shingles shots, travel vaccines, and more. Walk-ins welcome. All insurance accepted, including Medicare Part D and Medicaid."
  schema={schema}
>
  <section class="bg-[#0F3460] text-white py-16">
    <div class="container-site">
      <nav class="text-sm text-white/60 mb-4">
        <a href="/" class="hover:text-white">Home</a> / <a href="/services" class="hover:text-white">Services</a> / <span class="text-white">Immunizations</span>
      </nav>
      <span class="inline-block bg-[#17A2B8] text-white text-xs font-bold px-3 py-1 rounded-full mb-4">Walk-ins Welcome</span>
      <h1 class="text-4xl md:text-5xl font-extrabold mb-4">Immunizations & Vaccines<br>in Stafford, TX</h1>
      <p class="text-white/80 text-lg max-w-2xl">Stay protected. TRS Pharmacy offers a full range of vaccinations for children and adults — accepted by all major insurance and available to self-pay patients at low cost.</p>
      <div class="mt-8 flex flex-wrap gap-4">
        <a href="tel:3462304148" class="btn-primary">Call 346-230-4148</a>
        <a href="/contact" class="btn-outline">Schedule a Visit</a>
      </div>
    </div>
  </section>

  <section class="container-site py-20">
    <div class="grid md:grid-cols-2 gap-16 items-start">
      <div>
        <h2 class="section-title">Vaccines We Offer</h2>
        <p class="section-sub mb-8">Our pharmacist is fully certified to administer vaccinations. No appointment necessary for most vaccines.</p>
        <div class="grid grid-cols-2 gap-3">
          {vaccines.map(v => (
            <div class="flex items-center gap-3 bg-white border border-gray-200 rounded-xl px-4 py-3 shadow-sm text-sm font-medium text-[#1E293B]">
              <svg class="w-4 h-4 text-[#17A2B8] shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
              {v}
            </div>
          ))}
        </div>
      </div>
      <div class="space-y-6">
        <div class="bg-[#F8FAFC] rounded-2xl border border-gray-200 p-6">
          <h3 class="font-bold text-[#0F3460] text-lg mb-3">Why Vaccinate at TRS?</h3>
          <ul class="space-y-3 text-sm text-[#64748B]">
            {[
              'Walk-ins welcome — no appointment required for most vaccines',
              'All major insurance accepted, including Medicare Part D and Medicaid',
              'Low self-pay pricing for uninsured patients',
              'Friendly, knowledgeable staff to answer your questions',
              'Located in Stafford, TX — serving Sugar Land, Missouri City, and SW Houston',
            ].map(item => (
              <li class="flex gap-3">
                <svg class="w-4 h-4 text-[#17A2B8] mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                {item}
              </li>
            ))}
          </ul>
        </div>
        <div class="bg-white rounded-2xl border border-gray-200 p-6 shadow-sm">
          <p class="font-bold text-[#0F3460] mb-2">Location & Hours</p>
          <p class="text-sm text-[#64748B]">3727 Greenbriar Dr, Suite 114<br>Stafford, TX 77477</p>
          <p class="text-sm text-[#64748B] mt-2">Mon – Sat: 9:00 AM – 5:00 PM</p>
        </div>
        <InsuranceGrid />
      </div>
    </div>
  </section>

  <CTABanner
    heading="Get Your Vaccination in Stafford, TX Today"
    subtext="Walk-ins welcome. All insurance accepted. Call ahead to confirm vaccine availability."
    ctaLabel="Call 346-230-4148"
    secondaryLabel="Get Directions"
    secondaryHref="/contact"
  />
</Base>
