---
import Base from '../layouts/Base.astro';
import TrustBar from '../components/TrustBar.astro';
import CTABanner from '../components/CTABanner.astro';
import MapEmbed from '../components/MapEmbed.astro';
import InsuranceGrid from '../components/InsuranceGrid.astro';

const services = [
  { title: 'Immunizations & Vaccines', desc: 'Flu, COVID, Shingles, Hepatitis, HPV, travel vaccines and more — walk-ins welcome.', href: '/services/immunizations' },
  { title: 'Diabetes Care Center', desc: 'Specialized pharmacy support for Type 1, Type 2, and Gestational Diabetes.', href: '/services/diabetes-care' },
  { title: 'Free Prescription Delivery', desc: 'Free delivery within 10 miles. Free for 3+ prescriptions anywhere in the area.', href: '/services/prescription-delivery' },
  { title: 'Precision Medicine (PGx)', desc: 'Pharmacogenomics testing — the right medication for your unique genetic profile.', href: '/services/precision-medicine' },
  { title: 'Point-of-Care Testing', desc: 'Flu, strep, COVID-19 rapid testing available in-store without an appointment.', href: '/services/point-of-care-testing' },
  { title: 'Nutrient Depletion Analysis', desc: 'Find out if your medications are depleting essential vitamins and minerals.', href: '/services/nutrient-depletion' },
  { title: 'Prescription Refills & Transfers', desc: 'Easy online refills and hassle-free transfers from any pharmacy.', href: '/services/prescription-refills' },
  { title: 'Health Screenings', desc: 'Blood pressure, blood glucose, and other screenings — free or low-cost.', href: '/services/health-screenings' },
];

const testimonials = [
  { quote: "TRS Pharmacy has been a lifesaver for our family. They work with our insurance AND helped us when we didn't have coverage. Truly a community gem.", name: 'Maria G.', location: 'Stafford, TX' },
  { quote: "I transferred my 6 prescriptions in one call. The team is so knowledgeable — Dr. Waseem actually called me about a potential drug interaction. That never happens at a chain.", name: 'James T.', location: 'Missouri City, TX' },
  { quote: "Free delivery, great prices, and they actually pick up the phone. I've been coming here for 2 years and won't go anywhere else.", name: 'Fatima A.', location: 'Sugar Land, TX' },
];
---

<Base
  title="TRS Pharmacy — Stafford, TX | Nonprofit Community Pharmacy Serving All Insurance & Self-Pay"
  description="TRS Pharmacy is a 501(c)(3) nonprofit community pharmacy in Stafford, TX. We accept all major insurance, Medicare, Medicaid, and offer the best self-pay pricing. Free delivery within 10 miles. Call 346-230-4148."
>
  <!-- HERO -->
  <section class="bg-[#0F3460] text-white">
    <div class="container-site py-20 md:py-28 grid md:grid-cols-2 gap-12 items-center">
      <div>
        <p class="text-[#17A2B8] font-semibold text-sm uppercase tracking-widest mb-3">Stafford, TX · 501(c)(3) Nonprofit</p>
        <h1 class="text-4xl md:text-5xl font-extrabold leading-tight mb-5">
          Stafford's Trusted<br>Community Pharmacy
        </h1>
        <p class="text-white/80 text-lg mb-8 max-w-lg">
          TRS Pharmacy accepts <strong class="text-white">all major insurance</strong>, Medicare, Medicaid, and provides the <strong class="text-white">best self-pay pricing</strong> — we find you the lowest cost. Free delivery within 10 miles.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="tel:3462304148" class="btn-primary text-base">Call 346-230-4148</a>
          <a href="/services/prescription-refills" class="btn-outline text-base">Refill a Prescription</a>
        </div>
        <p class="mt-5 text-white/60 text-sm">Mon–Sat: 9 AM – 5 PM · 3727 Greenbriar Dr, Suite 114, Stafford TX</p>
      </div>
      <div class="hidden md:block">
        <div class="bg-[#17A2B8]/20 rounded-2xl p-8 border border-white/10">
          <p class="text-white font-bold text-xl mb-6">Quick Actions</p>
          <div class="flex flex-col gap-3">
            <a href="/services/prescription-refills" class="flex items-center gap-3 bg-white/10 hover:bg-white/20 rounded-xl px-5 py-4 transition-colors">
              <svg class="w-5 h-5 text-[#17A2B8]" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182m0-4.991v4.99" /></svg>
              <span class="font-semibold">Refill a Prescription</span>
            </a>
            <a href="/services/prescription-refills" class="flex items-center gap-3 bg-white/10 hover:bg-white/20 rounded-xl px-5 py-4 transition-colors">
              <svg class="w-5 h-5 text-[#17A2B8]" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M7.5 21L3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5" /></svg>
              <span class="font-semibold">Transfer Your Prescriptions</span>
            </a>
            <a href="/services/prescription-delivery" class="flex items-center gap-3 bg-white/10 hover:bg-white/20 rounded-xl px-5 py-4 transition-colors">
              <svg class="w-5 h-5 text-[#17A2B8]" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 00-3.213-9.193 2.056 2.056 0 00-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 00-10.026 0 1.106 1.106 0 00-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12" /></svg>
              <span class="font-semibold">Schedule Free Delivery</span>
            </a>
            <a href="/insurance-accepted" class="flex items-center gap-3 bg-white/10 hover:bg-white/20 rounded-xl px-5 py-4 transition-colors">
              <svg class="w-5 h-5 text-[#17A2B8]" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" /></svg>
              <span class="font-semibold">Check Insurance Coverage</span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- TRUST BAR -->
  <TrustBar />

  <!-- SERVICES -->
  <section class="container-site py-20">
    <div class="text-center mb-12">
      <h2 class="section-title">Pharmacy Services in Stafford, TX</h2>
      <p class="section-sub mx-auto">From immunizations to precision medicine, we offer comprehensive pharmacy services for every member of your family.</p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {services.map(s => (
        <a href={s.href} class="group bg-white rounded-2xl p-6 border border-gray-200 shadow-sm hover:shadow-md hover:border-[#17A2B8] transition-all">
          <div class="w-11 h-11 bg-[#F8FAFC] border border-[#17A2B8]/30 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-[#17A2B8]" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
            </svg>
          </div>
          <h3 class="font-bold text-[#0F3460] text-base mb-2 group-hover:text-[#17A2B8] transition-colors">{s.title}</h3>
          <p class="text-sm text-[#64748B] leading-relaxed">{s.desc}</p>
          <p class="mt-4 text-[#17A2B8] text-sm font-semibold">Learn more →</p>
        </a>
      ))}
    </div>
  </section>

  <!-- WHY TRS -->
  <section class="bg-white border-y border-gray-200 py-20">
    <div class="container-site grid md:grid-cols-2 gap-16 items-center">
      <div>
        <p class="text-[#17A2B8] font-semibold text-sm uppercase tracking-widest mb-3">Why Choose TRS</p>
        <h2 class="section-title">A Pharmacy Built for<br>Your Community</h2>
        <p class="text-[#64748B] leading-relaxed mb-6">TRS Pharmacy — The Rising Sun Pharmacy — is a 501(c)(3) nonprofit community pharmacy dedicated to making healthcare accessible for everyone in Stafford, TX and surrounding communities regardless of income or insurance status.</p>
        <ul class="space-y-4">
          {[
            ['All insurance accepted', 'Medicare Part D, Medicaid/CHIP, and all major commercial plans. (We do not accept MedImpact.)'],
            ['Best self-pay pricing', 'No insurance? We find you the lowest cost — typically at acquisition cost plus a small dispensing fee.'],
            ['Free prescription delivery', 'Free within 10 miles of Stafford, or for any order with 3+ prescriptions.'],
            ['Nonprofit mission', 'Every dollar goes back into serving patients, not shareholders.'],
          ].map(([title, body]) => (
            <li class="flex gap-4">
              <span class="mt-1 w-5 h-5 bg-[#17A2B8]/10 rounded-full flex items-center justify-center shrink-0">
                <svg class="w-3 h-3 text-[#17A2B8]" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 00-1.414 0L8 12.586 4.707 9.293a1 1 0 00-1.414 1.414l4 4a1 1 0 001.414 0l8-8a1 1 0 000-1.414z" clip-rule="evenodd"/></svg>
              </span>
              <div>
                <p class="font-semibold text-[#0F3460]">{title}</p>
                <p class="text-sm text-[#64748B]">{body}</p>
              </div>
            </li>
          ))}
        </ul>
        <a href="/about" class="inline-block mt-8 text-[#17A2B8] font-semibold hover:underline">Our mission and story →</a>
      </div>
      <div class="bg-[#F8FAFC] rounded-2xl p-8 border border-gray-200">
        <p class="font-bold text-[#0F3460] text-lg mb-1">Haroon Waseem, RPh PharmD</p>
        <p class="text-[#17A2B8] text-sm font-semibold mb-4">Community Pharmacist · Founder</p>
        <p class="text-[#64748B] leading-relaxed mb-4">A Xavier University of Louisiana graduate specializing in medication therapy management, alternative medicine, and chronic disease management — Dr. Waseem founded TRS to address healthcare gaps in the Stafford community.</p>
        <blockquote class="border-l-4 border-[#17A2B8] pl-4 text-[#1E293B] italic">"Our mission is to create a healthier society through compassionate, safe, and effective use of medications for all."</blockquote>
      </div>
    </div>
  </section>

  <!-- LOCATION + HOURS -->
  <section class="container-site py-20">
    <div class="text-center mb-12">
      <h2 class="section-title">Visit Us in Stafford, TX</h2>
      <p class="section-sub mx-auto">Conveniently located on Greenbriar Dr. We also serve Sugar Land, Missouri City, and SW Houston.</p>
    </div>
    <div class="grid md:grid-cols-2 gap-10 items-start">
      <MapEmbed />
      <div class="space-y-6">
        <div class="bg-white rounded-2xl border border-gray-200 p-6 shadow-sm">
          <p class="font-bold text-[#0F3460] mb-3">Address</p>
          <address class="not-italic text-[#64748B] leading-relaxed">
            3727 Greenbriar Dr, Suite 114<br>
            Stafford, TX 77477
          </address>
          <a href="https://maps.google.com/?q=3727+Greenbriar+Dr+Suite+114+Stafford+TX+77477" target="_blank" rel="noopener noreferrer" class="mt-3 inline-block text-[#17A2B8] font-semibold text-sm hover:underline">Get directions →</a>
        </div>
        <div class="bg-white rounded-2xl border border-gray-200 p-6 shadow-sm">
          <p class="font-bold text-[#0F3460] mb-3">Hours</p>
          <table class="w-full text-sm text-[#64748B]">
            <tbody>
              <tr><td class="py-1">Monday – Saturday</td><td class="text-right font-semibold text-[#1E293B]">9:00 AM – 5:00 PM</td></tr>
              <tr><td class="py-1">Sunday</td><td class="text-right font-semibold text-[#1E293B]">Closed</td></tr>
            </tbody>
          </table>
        </div>
        <div class="bg-white rounded-2xl border border-gray-200 p-6 shadow-sm">
          <p class="font-bold text-[#0F3460] mb-3">Contact</p>
          <div class="flex flex-col gap-2 text-sm">
            <a href="tel:3462304148" class="flex items-center gap-2 text-[#17A2B8] font-semibold hover:underline">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" /></svg>
              346-230-4148
            </a>
            <a href="mailto:info@trspharmacy.org" class="text-[#64748B] hover:text-[#17A2B8] transition-colors">info@trspharmacy.org</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- INSURANCE -->
  <section class="bg-white border-y border-gray-200 py-16">
    <div class="container-site">
      <div class="grid md:grid-cols-2 gap-10 items-center">
        <div>
          <h2 class="section-title">We Accept All Major Insurance</h2>
          <p class="section-sub">Including Medicare Part D, Medicaid, CHIP, and all major commercial plans. No insurance? We find you the best price — cost plus a small dispensing fee.</p>
          <div class="mt-6">
            <a href="/self-pay-pharmacy" class="text-[#17A2B8] font-semibold hover:underline text-sm">Learn about our self-pay pricing →</a>
          </div>
        </div>
        <InsuranceGrid />
      </div>
    </div>
  </section>

  <!-- TESTIMONIALS -->
  <section class="container-site py-20">
    <div class="text-center mb-12">
      <h2 class="section-title">What Our Patients Say</h2>
      <p class="section-sub mx-auto">Real reviews from patients across Stafford, Missouri City, and Sugar Land, TX.</p>
    </div>
    <div class="grid md:grid-cols-3 gap-6">
      {testimonials.map(t => (
        <div class="bg-white rounded-2xl p-6 border border-gray-200 shadow-sm">
          <div class="flex mb-3">
            {[1,2,3,4,5].map(_ => (
              <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            ))}
          </div>
          <p class="text-[#1E293B] italic mb-4">"{t.quote}"</p>
          <div>
            <p class="font-semibold text-[#0F3460] text-sm">{t.name}</p>
            <p class="text-[#64748B] text-xs">{t.location}</p>
          </div>
        </div>
      ))}
    </div>
    <div class="text-center mt-8">
      <a href="/reviews" class="text-[#17A2B8] font-semibold hover:underline">Read all reviews →</a>
    </div>
  </section>

  <!-- CTA BANNER -->
  <CTABanner />

  <!-- AREAS SERVED -->
  <section class="container-site py-16">
    <h2 class="section-title text-center mb-8">Areas We Serve</h2>
    <div class="flex flex-wrap justify-center gap-4">
      {[
        ['Stafford, TX', '/pharmacy-stafford-tx'],
        ['Sugar Land, TX', '/pharmacy-sugar-land-tx'],
        ['Missouri City, TX', '/pharmacy-missouri-city-tx'],
        ['SW Houston, TX', '/pharmacy-southwest-houston-tx'],
        ['Richmond / Rosenberg', '/pharmacy-richmond-rosenberg-tx'],
      ].map(([city, href]) => (
        <a href={href} class="bg-white border border-gray-200 hover:border-[#17A2B8] hover:text-[#17A2B8] text-[#1E293B] font-semibold px-5 py-2.5 rounded-full shadow-sm transition-all text-sm">
          {city}
        </a>
      ))}
    </div>
  </section>
</Base>
