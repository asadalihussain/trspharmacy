  </section>

  <!-- ======== AREAS SERVED ======== -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <p class="font-heading font-bold text-[#28759F] text-center mb-6">Areas We Serve</p>
    <div class="flex flex-wrap justify-center gap-3">
      {[
        ['Stafford, TX', '/pharmacy-stafford-tx'],
        ['Sugar Land, TX', '/pharmacy-sugar-land-tx'],
        ['Missouri City, TX', '/pharmacy-missouri-city-tx'],
        ['SW Houston, TX', '/pharmacy-southwest-houston-tx'],
        ['Richmond / Rosenberg', '/pharmacy-richmond-rosenberg-tx'],
      ].map(([city, href]) => (
        <a href={href} class="bg-white border border-[#B8DAEA] hover:border-[#28759F] hover:text-[#28759F] text-[#3589B5] font-semibold px-5 py-2.5 rounded-full shadow-sm transition-all text-sm">
          {city}
        </a>
      ))}
    </div>
  </section>

</Base>
