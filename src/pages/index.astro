---
import Base from '../layouts/Base.astro';

const services = [
  {
    title: 'Immunizations & Vaccines',
    desc: 'Walk-in or schedule flu, COVID-19, Shingles, and travel vaccines. Administered safely by our certified clinical pharmacists.',
    href: '/services/immunizations',
    bullets: ['Flu shots available now', 'Travel vaccines'],
    dark: false,
    accent: false,
  },
  {
    title: 'Diabetes Care Center',
    desc: 'Specialized support, meter training, and insulin management to help you maintain healthy glucose levels.',
    href: '/services/diabetes-care',
    dark: true,
  },
  {
    title: 'Point-of-Care Testing',
    desc: 'Rapid Flu, Strep, and COVID-19 tests. Results in minutes — and prescription treatment on the spot if needed.',
    href: '/services/point-of-care-testing',
    dark: false,
    accent: true,
  },
  {
    title: 'Precision Medicine (PGx)',
    desc: 'Pharmacogenomic testing reveals how your DNA affects medication response. No more trial and error.',
    href: '/services/precision-medicine',
    dark: false,
    warm: true,
  },
  {
    title: 'Health Screenings',
    desc: 'Blood pressure, cholesterol, and A1C checks — fast, no appointment needed.',
    href: '/services/health-screenings',
    dark: false,
  },
  {
    title: 'Free Local Delivery',
    desc: "Can't make it in? We'll bring your medications to your door — free within 10 miles.",
    href: '/services/prescription-delivery',
    delivery: true,
  },
];

const testimonials = [
  {
    quote: "TRS Pharmacy has been a lifesaver for our family. They work with our insurance AND helped us when we didn't have coverage. Dr. Waseem actually called me about a potential drug interaction — that never happens at a chain.",
    name: 'Maria G.',
    location: 'Stafford, TX',
    initial: 'M',
  },
  {
    quote: "I transferred my 6 prescriptions in one call. Free delivery, great prices, and they actually pick up the phone. I've been coming here for 2 years and won't go anywhere else.",
    name: 'James T.',
    location: 'Missouri City, TX',
    initial: 'J',
  },
  {
    quote: "The fact that I get a real human pharmacist on the phone is incredible. They handle prior authorizations with my doctor too. Truly a community gem.",
    name: 'Fatima A.',
    location: 'Sugar Land, TX',
    initial: 'F',
  },
];

const insurers = [
  { name: 'Medicare',         logo: '/images/insurers/medicare.svg'  },
  { name: 'Medicaid',         logo: '/images/insurers/medicaid.svg'  },
  { name: 'BCBS',             logo: '/images/insurers/bcbs.svg'      },
  { name: 'UnitedHealthcare', logo: '/images/insurers/uhc.svg'       },
  { name: 'Humana',           logo: '/images/insurers/humana.svg'    },
  { name: 'Cigna',            logo: '/images/insurers/cigna.svg'     },
  { name: 'Aetna',            logo: '/images/insurers/aetna.svg'     },
  { name: 'Ambetter',         logo: '/images/insurers/ambetter.svg'  },
  { name: 'Oscar',            logo: '/images/insurers/oscar.svg'     },
  { name: 'Molina',           logo: '/images/insurers/molina.svg'    },
];
---

<Base
  title="TRS Pharmacy — Stafford, TX | Nonprofit Community Pharmacy"
  description="TRS Pharmacy is a 501(c)(3) nonprofit community pharmacy in Stafford, TX. We accept all major insurance, Medicare, Medicaid, and offer the best self-pay pricing. Free delivery within 10 miles. Call 346-230-4148."
>

  <!-- ======== HERO ======== -->
  <section class="relative pt-10 pb-12 lg:pt-20 lg:pb-16 overflow-hidden">

    <!-- Ambient blobs -->
    <div class="pointer-events-none absolute inset-0 -z-10 overflow-hidden">
      <div class="absolute -top-24 -left-24 w-[500px] h-[500px] rounded-full bg-[#DCF0F8]/60 blur-[80px] animate-blob"></div>
      <div class="absolute top-32 -right-24 w-[420px] h-[420px] rounded-full bg-[#FDE9E3]/60 blur-[80px] animate-blob" style="animation-delay:2s"></div>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 items-center">

        <!-- Left: copy -->
        <div>
          <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-[#DCF0F8] text-[#1E5A78] font-semibold text-xs tracking-wide uppercase mb-6 border border-[#B8DAEA]">
            <span class="w-2 h-2 rounded-full bg-[#F16742] animate-pulse"></span>
            Stafford's Nonprofit Pharmacy
          </div>

          <h1 class="font-heading text-5xl sm:text-6xl lg:text-[4rem] font-bold leading-[1.1] text-[#0C2535] mb-6 tracking-tight">
            Care that treats<br>you like <span class="text-[#28759F] relative">family.<svg class="absolute -bottom-1 left-0 w-full" viewBox="0 0 200 8" preserveAspectRatio="none" fill="none"><path d="M0 6 C50 0, 150 0, 200 6" stroke="#F16742" stroke-width="3" stroke-linecap="round"/></svg></span><br>
            <span class="text-[#3589B5]">Not a file.</span>
          </h1>

          <p class="text-lg text-[#27709A] mb-8 max-w-lg leading-relaxed">
            As a <strong class="text-[#28759F]">501(c)(3) nonprofit</strong>, we put patients over profits. All major insurances accepted, including Medicare and Medicaid — plus the best self-pay pricing in Stafford.
          </p>

          <div class="flex flex-col sm:flex-row gap-4 mb-10">
            <a href="/services/prescription-refills" class="flex items-center justify-center gap-2 bg-[#28759F] text-white px-8 py-4 rounded-full font-heading font-semibold text-lg hover:bg-[#0C2535] transition-all group">
              Transfer Prescriptions
              <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" /></svg>
            </a>
            <a href="tel:3462304148" class="flex items-center justify-center gap-2 bg-white text-[#28759F] border-2 border-[#B8DAEA] px-8 py-4 rounded-full font-heading font-semibold text-lg hover:border-[#6AAFC9] hover:bg-[#EEF5FA] transition-all">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" /></svg>
              Call 346-230-4148
            </a>
          </div>

          <!-- Social proof -->
          <div class="flex items-center gap-4">
            <div class="flex -space-x-3">
              {['M','J','F','L'].map((letter, i) => (
                <div class={`w-10 h-10 rounded-full border-2 border-sand flex items-center justify-center text-xs font-bold text-white ${i === 0 ? 'bg-[#28759F]' : i === 1 ? 'bg-[#27709A]' : i === 2 ? 'bg-[#F16742]' : 'bg-[#3589B5]'}`}>
                  {letter}
                </div>
              ))}
              <div class="w-10 h-10 rounded-full border-2 border-sand bg-[#DCF0F8] flex items-center justify-center text-xs font-bold text-[#28759F]">5k+</div>
            </div>
            <p class="text-sm font-medium text-[#27709A] leading-tight">Trusted by families<br>across Fort Bend County</p>
          </div>
        </div>

        <!-- Right: hero image -->
        <div class="relative max-w-lg mx-auto lg:mx-0 lg:ml-auto">
          <div class="absolute inset-0 border-2 border-[#F16742]/25 rounded-[40px] translate-x-4 translate-y-4"></div>
          <img
            src="https://images.unsplash.com/photo-1579154204601-01588f351e67?auto=format&fit=crop&w=800&q=80"
            alt="Pharmacist consulting with a patient"
            class="relative w-full aspect-[4/5] object-cover rounded-[40px] shadow-[0_10px_40px_-10px_rgba(40,117,159,0.15)] z-10"
          />
          <!-- Floating badge -->
          <div class="absolute bottom-8 -left-6 z-20 glass-panel bg-white/90 px-4 py-3 rounded-2xl shadow-lg flex items-center gap-3">
            <div class="w-10 h-10 bg-[#FDE9E3] rounded-full flex items-center justify-center text-[#F16742] shrink-0">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" /></svg>
            </div>
            <div>
              <p class="text-[0.65rem] font-bold text-[#6AAFC9] uppercase tracking-wider">Our Commitment</p>
              <p class="font-heading font-bold text-[#28759F] text-sm leading-tight">Patient-First Care</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Quick-action bento (floats at hero bottom edge) -->
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 mt-10 lg:mt-12 relative z-20">
      <div class="bg-white p-2 sm:p-3 rounded-[28px] shadow-[0_20px_50px_-12px_rgba(40,117,159,0.10)] border border-[#DCF0F8]">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-2 sm:gap-3">

          <a href="/services/prescription-refills" class="group relative overflow-hidden bg-[#EEF5FA] rounded-[20px] p-5 transition-all duration-300 hover:bg-[#28759F] flex flex-col justify-between min-h-[148px]">
            <div class="w-11 h-11 rounded-full bg-white shadow-sm flex items-center justify-center text-[#28759F] group-hover:text-[#F16742] transition-colors mb-3">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182m0-4.991v4.99" /></svg>
            </div>
            <div>
              <p class="font-heading font-bold text-[#28759F] group-hover:text-white transition-colors">Refill Meds</p>
              <p class="text-xs text-[#3589B5] group-hover:text-[#9EC8DC] mt-0.5 transition-colors">Quick & easy</p>
            </div>
            <svg class="absolute top-5 right-5 w-4 h-4 text-white opacity-0 translate-x-2 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" /></svg>
          </a>

          <a href="/services/prescription-refills" class="group relative overflow-hidden bg-[#FDE9E3] rounded-[20px] p-5 transition-all duration-300 hover:bg-[#F16742] flex flex-col justify-between min-h-[148px]">
            <div class="w-11 h-11 rounded-full bg-white shadow-sm flex items-center justify-center text-[#F16742] group-hover:text-[#28759F] transition-colors mb-3">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M7.5 21L3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5" /></svg>
            </div>
            <div>
              <p class="font-heading font-bold text-[#C03D1E] group-hover:text-white transition-colors">Transfer Rx</p>
              <p class="text-xs text-[#C03D1E]/70 group-hover:text-[#FDE9E3] mt-0.5 transition-colors">Move to TRS today</p>
            </div>
            <svg class="absolute top-5 right-5 w-4 h-4 text-white opacity-0 translate-x-2 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" /></svg>
          </a>

          <a href="/services/prescription-delivery" class="group overflow-hidden bg-[#F8F6F2] border border-[#DCF0F8] rounded-[20px] p-5 transition-all duration-300 hover:border-[#B8DAEA] hover:bg-white flex flex-col justify-between min-h-[148px]">
            <div class="w-11 h-11 rounded-full bg-[#DCF0F8] flex items-center justify-center text-[#28759F] mb-3 transition-transform group-hover:scale-110">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 00-3.213-9.193 2.056 2.056 0 00-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 00-10.026 0 1.106 1.106 0 00-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12" /></svg>
            </div>
            <div>
              <p class="font-heading font-bold text-[#28759F]">Free Delivery</p>
              <p class="text-xs text-[#3589B5] mt-0.5">To your doorstep</p>
            </div>
          </a>

          <a href="/insurance-accepted" class="group overflow-hidden bg-[#F8F6F2] border border-[#DCF0F8] rounded-[20px] p-5 transition-all duration-300 hover:border-[#B8DAEA] hover:bg-white flex flex-col justify-between min-h-[148px]">
            <div class="w-11 h-11 rounded-full bg-[#DCF0F8] flex items-center justify-center text-[#28759F] mb-3 transition-transform group-hover:scale-110">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" /></svg>
            </div>
            <div>
              <p class="font-heading font-bold text-[#28759F]">Check Coverage</p>
              <p class="text-xs text-[#3589B5] mt-0.5">Medicare & Medicaid</p>
            </div>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ======== INSURANCE MARQUEE ======== -->
  <section id="insurance" class="py-8 bg-white border-y border-[#DCF0F8] overflow-hidden">
    <p class="text-center text-xs font-bold text-[#6AAFC9] uppercase tracking-widest mb-5">We Accept All Major Providers</p>
    <div class="relative flex overflow-hidden [mask-image:linear-gradient(to_right,transparent,black_15%,black_85%,transparent)]">
      <!-- Two identical lists for seamless loop -->
      <ul class="flex shrink-0 gap-12 items-center animate-marquee whitespace-nowrap pr-12">
        {insurers.map(ins => (
          <li class="flex items-center shrink-0">
            <img
              src={ins.logo}
              alt={ins.name}
              width="120"
              height="40"
              class="h-9 w-auto object-contain grayscale opacity-50 hover:grayscale-0 hover:opacity-100 transition-all duration-300"
              loading="lazy"
            />
          </li>
        ))}
      </ul>
      <ul class="flex shrink-0 gap-12 items-center animate-marquee whitespace-nowrap pr-12" aria-hidden="true">
        {insurers.map(ins => (
          <li class="flex items-center shrink-0">
            <img
              src={ins.logo}
              alt={ins.name}
              width="120"
              height="40"
              class="h-9 w-auto object-contain grayscale opacity-50 hover:grayscale-0 hover:opacity-100 transition-all duration-300"
              loading="lazy"
            />
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ======== SERVICES ======== -->
  <section id="services" class="py-24 bg-[#F8F6F2]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="md:flex justify-between items-end gap-8 mb-14">
        <div class="max-w-xl">
          <span class="inline-block py-1 px-3 rounded-full bg-white border border-[#B8DAEA] text-[#C03D1E] text-xs font-bold uppercase tracking-wider mb-4">Complete Health Ecosystem</span>
          <h2 class="font-heading text-4xl lg:text-5xl font-bold text-[#0C2535] leading-tight">More than just<br>prescriptions.</h2>
        </div>
        <p class="mt-6 md:mt-0 max-w-sm text-sm text-[#3589B5] leading-relaxed">Full-scope preventative care, chronic condition management, and rapid diagnostics — right here in Stafford, TX.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {services.map(s => {
          if (s.dark) return (
            <a href={s.href} class="group bg-[#28759F] rounded-[28px] p-8 flex flex-col relative overflow-hidden hover:bg-[#1E5A78] transition-colors">
              <div class="absolute top-0 right-0 w-28 h-28 bg-[#1E5A78] rounded-bl-full -mr-4 -mt-4 transition-transform group-hover:scale-110"></div>
              <div class="relative z-10">
                <div class="w-11 h-11 bg-[#1E5A78] rounded-xl flex items-center justify-center text-white mb-5">
                  <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0112 15a9.065 9.065 0 00-6.23-.693L5 14.5m14.8.8 1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0112 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5" /></svg>
                </div>
                <h3 class="font-heading font-bold text-xl text-white mb-2">{s.title}</h3>
                <p class="text-[#9EC8DC] text-sm leading-relaxed">{s.desc}</p>
              </div>
            </a>
          );
          if (s.accent) return (
            <a href={s.href} class="group bg-white rounded-[28px] p-8 flex flex-col border border-[#DCF0F8] hover:shadow-[0_10px_40px_-10px_rgba(40,117,159,0.08)] transition-all">
              <div class="w-11 h-11 bg-[#FDE9E3] rounded-xl flex items-center justify-center text-[#C03D1E] mb-5">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5m4.75-11.396c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M5 14.5l-1.57.393A9.065 9.065 0 0012 15a9.065 9.065 0 006.23-.693L19.8 15.3m0 0 1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0112 21a48.25 48.25 0 01-8.135-.687c-1.718-.293-2.3-2.379-1.067-3.61L5 14.5" /></svg>
              </div>
              <h3 class="font-heading font-bold text-xl text-[#0C2535] mb-2">{s.title}</h3>
              <p class="text-[#3589B5] text-sm leading-relaxed">{s.desc}</p>
            </a>
          );
          if (s.warm) return (
            <a href={s.href} class="group bg-[#FDE6DF] rounded-[28px] p-8 flex flex-col hover:shadow-[0_10px_40px_-10px_rgba(241,103,66,0.12)] transition-all">
              <div class="w-11 h-11 bg-white rounded-xl flex items-center justify-center text-[#C03D1E] mb-5">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5m4.75-11.396c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M5 14.5l-1.57.393A9.065 9.065 0 0012 15a9.065 9.065 0 006.23-.693L19.8 15.3m0 0 1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0112 21a48.25 48.25 0 01-8.135-.687c-1.718-.293-2.3-2.379-1.067-3.61L5 14.5" /></svg>
              </div>
              <h3 class="font-heading font-bold text-xl text-[#0C2535] mb-2">{s.title}</h3>
              <p class="text-[#8B3520] text-sm leading-relaxed">{s.desc}</p>
            </a>
          );
          if (s.delivery) return (
            <a href={s.href} class="group bg-white rounded-[28px] p-8 flex flex-col items-center text-center border border-[#DCF0F8] hover:shadow-[0_10px_40px_-10px_rgba(40,117,159,0.08)] transition-all">
              <div class="w-14 h-14 bg-[#DCF0F8] rounded-full flex items-center justify-center text-[#28759F] mb-4 transition-transform group-hover:scale-110">
                <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 00-3.213-9.193 2.056 2.056 0 00-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 00-10.026 0 1.106 1.106 0 00-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12" /></svg>
              </div>
              <h3 class="font-heading font-bold text-xl text-[#0C2535] mb-2">{s.title}</h3>
              <p class="text-[#3589B5] text-sm leading-relaxed mb-4">{s.desc}</p>
              <span class="text-[#F16742] font-bold text-xs uppercase tracking-wide flex items-center gap-1">
                Schedule Setup
                <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" /></svg>
              </span>
            </a>
          );
          // Default card
          return (
            <a href={s.href} class="group bg-white rounded-[28px] p-8 flex flex-col border border-[#DCF0F8] hover:shadow-[0_10px_40px_-10px_rgba(40,117,159,0.08)] transition-all">
              <div class="w-11 h-11 bg-[#DCF0F8] rounded-xl flex items-center justify-center text-[#28759F] mb-5">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
              </div>
              <h3 class="font-heading font-bold text-xl text-[#0C2535] mb-2">{s.title}</h3>
              <p class="text-[#3589B5] text-sm leading-relaxed">{s.desc}</p>
            </a>
          );
        })}
      </div>

      <div class="mt-10 text-center">
        <a href="/services" class="inline-flex items-center gap-2 text-[#28759F] font-semibold hover:text-[#F16742] transition-colors text-sm">
          View all services
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" /></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ======== FOUNDER / MISSION ======== -->
  <section id="mission" class="py-24 bg-[#112923] text-white relative overflow-hidden">
    <!-- Organic SVG shape -->
    <svg class="absolute top-0 right-0 h-full w-1/2 text-[#1F473E] opacity-40 translate-x-1/3 pointer-events-none" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
      <path fill="currentColor" d="M42.7,-73.4C55.9,-65.4,67.6,-53.4,76.5,-39.3C85.4,-25.2,91.5,-9.1,88.9,6C86.3,21.1,75.1,35.1,63.1,46.7C51.1,58.3,38.2,67.5,23.6,73.5C9,79.5,-7.2,82.3,-21.8,78.8C-36.4,75.3,-49.5,65.5,-61.1,53.5C-72.7,41.5,-82.9,27.3,-86.3,11.3C-89.8,-4.6,-86.6,-22.3,-77.7,-36.8C-68.8,-51.2,-54.2,-62.4,-40,-70C-25.8,-77.6,-12.9,-81.6,1.4,-84C15.8,-86.4,31.5,-87.3,42.7,-73.4Z" transform="translate(100 100)" />
    </svg>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="grid lg:grid-cols-2 gap-16 items-center">

        <!-- Portrait -->
        <div class="relative max-w-md mx-auto lg:mx-0">
          <div class="absolute inset-0 bg-[#F16742] translate-x-5 translate-y-5 rounded-[32px]"></div>
          <img
            src="https://images.unsplash.com/photo-1622253692010-333f2da6031d?auto=format&fit=crop&w=800&q=80"
            alt="Dr. Haroon Waseem, RPh PharmD — Founder of TRS Pharmacy"
            class="relative w-full h-[460px] sm:h-[500px] object-cover rounded-[32px]"
          />
          <div class="absolute -bottom-5 -left-5 bg-white text-[#112923] px-5 py-4 rounded-2xl shadow-xl border border-[#E5EDE7]">
            <p class="font-heading font-black text-lg leading-tight text-[#1F473E]">Dr. Haroon Waseem</p>
            <p class="text-xs text-[#7B9F91] font-semibold uppercase tracking-widest mt-0.5">RPh PharmD · Founder</p>
          </div>
        </div>

        <!-- Story -->
        <div>
          <svg class="w-10 h-10 text-[#F16742] opacity-50 mb-5" fill="currentColor" viewBox="0 0 24 24"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/></svg>

          <h2 class="font-heading text-3xl sm:text-4xl lg:text-5xl font-bold leading-tight mb-8 text-white">
            "Corporate pharmacies see quotas.<br>We see our neighbors."
          </h2>

          <div class="space-y-5 text-[#AEC8BD] text-lg leading-relaxed font-light">
            <p>
              I started TRS Pharmacy because I saw too many families falling through the cracks of a cold, automated healthcare system — patients who couldn't get questions answered, and pricing that was completely untransparent.
            </p>
            <p>
              Establishing TRS as a <strong class="text-white font-semibold">501(c)(3) nonprofit</strong> allowed us to flip that model. We don't report to shareholders — we report to the Stafford community.
            </p>
            <p class="text-white font-medium border-l-4 border-[#F16742] pl-5 py-1">
              Whether you're on Medicare, Medicaid, or paying out of pocket — you deserve dignity, time, and world-class clinical care.
            </p>
          </div>

          <a href="/about" class="inline-flex items-center gap-2 mt-8 text-[#F16742] font-semibold hover:text-white transition-colors">
            Our full story
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" /></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ======== TESTIMONIALS ======== -->
  <section class="py-24 bg-[#F9F7F3]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-14">
        <h2 class="font-heading text-3xl sm:text-4xl font-bold text-[#0C2535] mb-3">Loved by our Stafford family.</h2>
        <p class="text-[#3589B5]">Real reviews from patients across Stafford, Missouri City, and Sugar Land, TX.</p>
      </div>

      <div class="grid md:grid-cols-3 gap-6 items-start">
        {testimonials.map((t, i) => (
          <div class={`bg-white p-7 rounded-[24px] shadow-[0_4px_20px_-8px_rgba(40,117,159,0.10)] border border-[#DCF0F8] ${i === 1 ? 'md:mt-8' : i === 2 ? 'md:mt-16' : ''}`}>
            <div class="flex gap-0.5 mb-4">
              {[1,2,3,4,5].map(_ => (
                <svg class="w-4 h-4 text-[#F16742]" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              ))}
            </div>
            <p class="text-[#1E5A78] text-sm leading-relaxed mb-5">"{t.quote}"</p>
            <div class="flex items-center gap-3">
              <div class="w-9 h-9 rounded-full bg-[#DCF0F8] flex items-center justify-center font-heading font-bold text-[#28759F] text-sm">{t.initial}</div>
              <div>
                <p class="font-semibold text-[#0C2535] text-sm">{t.name}</p>
                <p class="text-[#6AAFC9] text-xs">{t.location}</p>
              </div>
            </div>
          </div>
        ))}
      </div>

      <div class="text-center mt-10">
        <a href="/reviews" class="text-[#28759F] font-semibold hover:text-[#F16742] transition-colors text-sm">
          Read all reviews →
        </a>
      </div>
    </div>
  </section>

  <!-- ======== LOCATION CTA ======== -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-24">
    <div class="bg-[#28759F] rounded-[36px] overflow-hidden shadow-2xl flex flex-col lg:flex-row">

      <!-- Text half -->
      <div class="lg:w-1/2 p-10 lg:p-14 flex flex-col justify-center">
        <h2 class="font-heading text-3xl sm:text-4xl font-bold text-white mb-3">Ready for better care?</h2>
        <p class="text-[#9EC8DC] mb-10 leading-relaxed max-w-sm">Transferring takes less than 2 minutes. Give us your info — we call your old pharmacy and doctor so you don't have to.</p>

        <div class="space-y-5 mb-10">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-full bg-[#1E5A78] flex items-center justify-center text-[#F16742] shrink-0">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" /></svg>
            </div>
            <div>
              <p class="text-white font-semibold">Visit Us in Stafford</p>
              <p class="text-[#9EC8DC] text-sm mt-0.5">3727 Greenbriar Dr, Suite 114<br>Stafford, TX 77477</p>
            </div>
          </div>
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-full bg-[#1E5A78] flex items-center justify-center text-[#F16742] shrink-0">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            </div>
            <div>
              <p class="text-white font-semibold">Hours</p>
              <p class="text-[#9EC8DC] text-sm mt-0.5">Mon – Sat: 9:00 AM – 5:00 PM<br>Sunday: Closed</p>
            </div>
          </div>
        </div>

        <div class="flex flex-col sm:flex-row gap-3">
          <a href="/services/prescription-refills" class="bg-[#F16742] hover:bg-[#D4522E] text-white text-center px-8 py-3.5 rounded-full font-heading font-semibold transition-all shadow-[0_4px_14px_0_rgba(241,103,66,0.4)]">Transfer to TRS</a>
          <a href="tel:3462304148" class="bg-[#1E5A78] hover:bg-[#27709A] text-white text-center px-8 py-3.5 rounded-full font-heading font-semibold transition-all border border-[#27709A]">346-230-4148</a>
        </div>
      </div>

      <!-- Map half -->
      <div class="lg:w-1/2 min-h-[300px] relative overflow-hidden">
        <iframe
          src="https://maps.google.com/maps?q=3727+Greenbriar+Dr,+Suite+114,+Stafford,+TX+77477&output=embed&z=16"
          class="absolute inset-0 w-full h-full border-0"
          allowfullscreen
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="TRS Pharmacy location map"
        ></iframe>
      </div>
