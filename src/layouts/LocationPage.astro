---
import Base from './Base.astro';
import CTABanner from '../components/CTABanner.astro';
import MapEmbed from '../components/MapEmbed.astro';
import InsuranceGrid from '../components/InsuranceGrid.astro';

interface Props {
  city: string;
  state: string;
  slug: string;
  distanceFromStafford: string;
  zipCodes?: string[];
  description: string;
  nearbyNote: string;
}

const { city, state, slug, distanceFromStafford, zipCodes, description, nearbyNote } = Astro.props;

const services = [
  { label: 'Immunizations & Vaccines', href: '/services/immunizations' },
  { label: 'Free Prescription Delivery', href: '/services/prescription-delivery' },
  { label: 'Diabetes Care', href: '/services/diabetes-care' },
  { label: 'Precision Medicine (PGx)', href: '/services/precision-medicine' },
  { label: 'Point-of-Care Testing', href: '/services/point-of-care-testing' },
  { label: 'Prescription Refills & Transfers', href: '/services/prescription-refills' },
];

const locationSchema = {
  "@context": "https://schema.org",
  "@type": "Pharmacy",
  "name": "TRS Pharmacy",
  "description": `TRS Pharmacy in Stafford, TX serves ${city}, ${state} residents with free prescription delivery, immunizations, and full pharmacy services. All insurance accepted.`,
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "3727 Greenbriar Dr, Suite 114",
    "addressLocality": "Stafford",
    "addressRegion": "TX",
    "postalCode": "77477"
  },
  "areaServed": { "@type": "City", "name": city },
  "telephone": "+13462304148"
};
---

<Base
  title={`Pharmacy Serving ${city}, ${state} | TRS Pharmacy Stafford TX`}
  description={description}
  schema={locationSchema}
>
  <!-- HERO -->
  <section class="bg-[#0F3460] text-white py-16">
    <div class="container-site">
      <nav class="text-sm text-white/60 mb-4">
        <a href="/" class="hover:text-white">Home</a> / <span class="text-white">Pharmacy serving {city}, {state}</span>
      </nav>
      <h1 class="text-4xl md:text-5xl font-extrabold mb-4">
        TRS Pharmacy Serves<br>{city}, {state} Residents
      </h1>
      <p class="text-white/80 text-lg max-w-2xl mb-8">{nearbyNote}</p>
      <div class="flex flex-wrap gap-4">
        <a href="tel:3462304148" class="btn-primary">Call 346-230-4148</a>
        <a href="/services/prescription-delivery" class="btn-outline">Check Free Delivery</a>
      </div>
    </div>
  </section>

  <!-- TRUST BAR -->
  <div class="bg-white border-b border-gray-200">
    <div class="container-site py-4 grid grid-cols-2 md:grid-cols-4 gap-4 text-sm font-semibold text-[#1E293B]">
      <span class="flex gap-2 items-center"><span class="text-[#17A2B8]">✓</span> All Insurance Accepted</span>
      <span class="flex gap-2 items-center"><span class="text-[#17A2B8]">✓</span> Free Delivery Available</span>
      <span class="flex gap-2 items-center"><span class="text-[#17A2B8]">✓</span> Best Self-Pay Pricing</span>
      <span class="flex gap-2 items-center"><span class="text-[#17A2B8]">✓</span> 501(c)(3) Nonprofit</span>
    </div>
  </div>

  <!-- MAIN CONTENT -->
  <section class="container-site py-20">
    <div class="grid md:grid-cols-2 gap-16">
      <div>
        <h2 class="section-title">Full-Service Pharmacy for {city} Residents</h2>
        <p class="text-[#64748B] leading-relaxed mb-6">TRS Pharmacy is located in Stafford, TX — just {distanceFromStafford} from {city}. We provide the same high-quality, personalized pharmacy care to patients from {city} as to those right next door to our store.</p>

        {zipCodes && zipCodes.length > 0 && (
          <p class="text-[#64748B] mb-6">We serve patients in zip codes: <strong class="text-[#0F3460]">{zipCodes.join(', ')}</strong></p>
        )}

        <h3 class="text-xl font-bold text-[#0F3460] mb-4">Services Available to {city} Patients</h3>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          {services.map(s => (
            <a href={s.href} class="flex items-center gap-3 bg-white border border-gray-200 rounded-xl px-4 py-3 shadow-sm text-sm font-medium text-[#1E293B] hover:border-[#17A2B8] hover:text-[#17A2B8] transition-all">
              <svg class="w-4 h-4 text-[#17A2B8] shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
              {s.label}
            </a>
          ))}
        </div>

        <h3 class="text-xl font-bold text-[#0F3460] mt-8 mb-4">Free Delivery to {city}</h3>
        <p class="text-[#64748B] text-sm leading-relaxed">Free prescription delivery is available for any order of 3 or more prescriptions — with no distance limit. For 1–2 prescriptions, delivery within 10 miles of Stafford is always free. A $4 fee applies for smaller orders outside that radius.</p>
        <a href="/services/prescription-delivery" class="mt-3 inline-block text-[#17A2B8] font-semibold text-sm hover:underline">Full delivery details →</a>
      </div>

      <div class="space-y-6">
        <MapEmbed />
        <div class="bg-white rounded-2xl border border-gray-200 p-6 shadow-sm">
          <p class="font-bold text-[#0F3460] mb-3">TRS Pharmacy Location</p>
          <address class="not-italic text-sm text-[#64748B] leading-relaxed">
            3727 Greenbriar Dr, Suite 114<br>
            Stafford, TX 77477
          </address>
          <p class="text-sm text-[#64748B] mt-2">Mon – Sat: 9:00 AM – 5:00 PM</p>
          <div class="mt-3 flex flex-col gap-1">
            <a href="tel:3462304148" class="text-[#17A2B8] font-semibold text-sm hover:underline">346-230-4148</a>
            <a href="https://maps.google.com/?q=3727+Greenbriar+Dr+Suite+114+Stafford+TX+77477" target="_blank" rel="noopener noreferrer" class="text-[#17A2B8] text-sm font-semibold hover:underline">Get directions from {city} →</a>
          </div>
        </div>
        <InsuranceGrid />
      </div>
    </div>
  </section>

  <CTABanner
    heading={`Ready to Switch Pharmacies in ${city}?`}
    subtext={`Transferring all your prescriptions to TRS Pharmacy takes one phone call. We handle everything — and accept all major insurance.`}
  />
</Base>
