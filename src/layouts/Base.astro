---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  schema?: object | object[];
}

const { title, description, canonical, ogImage, schema } = Astro.props;
const canonicalURL = canonical ?? new URL(Astro.url.pathname, Astro.site).toString();
const ogImg = ogImage ?? '/images/og-default.png';

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": ["Pharmacy", "LocalBusiness", "MedicalOrganization"],
  "name": "TRS Pharmacy",
  "alternateName": "The Rising Sun Pharmacy",
  "url": "https://trspharmacy.org",
  "logo": "https://trspharmacy.org/images/logo.png",
  "image": "https://trspharmacy.org/images/og-default.png",
  "description": "TRS Pharmacy is a 501(c)(3) nonprofit community pharmacy in Stafford, TX serving patients with all insurance plans, Medicare, Medicaid, and self-pay at cost-plus pricing.",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "3727 Greenbriar Dr, Suite 114",
    "addressLocality": "Stafford",
    "addressRegion": "TX",
    "postalCode": "77477",
    "addressCountry": "US"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 29.6169,
    "longitude": -95.5548
  },
  "telephone": "+13462304148",
  "faxNumber": "+13462190414",
  "email": "info@trspharmacy.org",
  "openingHoursSpecification": [
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"],
      "opens": "09:00",
      "closes": "17:00"
    }
  ],
  "priceRange": "$",
  "currenciesAccepted": "USD",
  "paymentAccepted": "Cash, Credit Card, Insurance",
  "isNonprofitOrganization": true,
  "areaServed": [
    { "@type": "City", "name": "Stafford", "sameAs": "https://en.wikipedia.org/wiki/Stafford,_Texas" },
    { "@type": "City", "name": "Sugar Land" },
    { "@type": "City", "name": "Missouri City" },
    { "@type": "City", "name": "Houston" },
    { "@type": "City", "name": "Richmond" },
    { "@type": "City", "name": "Rosenberg" }
  ],
  "sameAs": [
    "https://www.facebook.com/trspharmacy",
    "https://www.instagram.com/trspharmacy"
  ]
};

const schemas = [localBusinessSchema, ...(schema ? (Array.isArray(schema) ? schema : [schema]) : [])];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#28759F" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImg} />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImg} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" />

    <!-- Icons -->
    <script src="https://unpkg.com/@phosphor-icons/web@2.1.1/src/index.js" is:inline></script>

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- JSON-LD Schema -->
    {schemas.map(s => (
      <script type="application/ld+json" set:html={JSON.stringify(s)} />
    ))}
  </head>
  <body class="bg-sand min-h-screen flex flex-col relative overflow-x-hidden">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
