---
const plans = [
  'Medicare Part D',
  'Medicaid / CHIP',
  'Blue Cross Blue Shield',
  'Aetna',
  'Cigna',
  'UnitedHealthcare',
  'Humana',
  'Ambetter',
  'Molina Healthcare',
  'Community Health Choice',
  'Oscar Health',
  'Tricare',
  'Self-Pay (Cost+)',
];
---

<div class="mt-8">
  <p class="text-sm font-semibold text-[#64748B] uppercase tracking-widest mb-4">Insurance Plans Accepted</p>
  <div class="flex flex-wrap gap-2">
    {plans.map(plan => (
      <span class="bg-white border border-gray-200 text-[#1E293B] text-sm font-medium px-3 py-1.5 rounded-full shadow-sm">{plan}</span>
    ))}
  </div>
  <p class="mt-3 text-sm text-[#64748B]">We accept most major insurance plans. <a href="/insurance-accepted" class="text-[#17A2B8] font-semibold hover:underline">See the full list →</a></p>
</div>
