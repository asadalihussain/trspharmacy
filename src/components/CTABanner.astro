---
interface Props {
  heading?: string;
  subtext?: string;
  ctaLabel?: string;
  ctaHref?: string;
  secondaryLabel?: string;
  secondaryHref?: string;
}

const {
  heading = 'Ready to Transfer Your Prescriptions?',
  subtext = 'Switch to TRS Pharmacy today. We accept all major insurance plans, Medicare, Medicaid, and offer the best self-pay pricing in Stafford, TX.',
  ctaLabel = 'Call 346-230-4148',
  ctaHref = 'tel:3462304148',
  secondaryLabel = 'Contact Us Online',
  secondaryHref = '/contact',
} = Astro.props;
---

<section class="bg-[#0F3460] py-16 mt-16">
  <div class="container-site text-center">
    <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">{heading}</h2>
    <p class="text-white/80 text-lg mb-8 max-w-2xl mx-auto">{subtext}</p>
    <div class="flex flex-wrap justify-center gap-4">
      <a href={ctaHref} class="btn-primary text-lg">{ctaLabel}</a>
      <a href={secondaryHref} class="btn-outline text-lg">{secondaryLabel}</a>
    </div>
  </div>
</section>
