---
const navLinks = [
  { label: 'Services', href: '/services' },
  { label: 'Insurance', href: '/insurance-accepted' },
  { label: 'Delivery', href: '/services/prescription-delivery' },
  { label: 'About', href: '/about' },
  { label: 'Blog', href: '/blog' },
  { label: 'Contact', href: '/contact' },
];
---

<header class="sticky top-0 z-50 bg-[#0F3460] shadow-md">
  <div class="container-site flex items-center justify-between h-16">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 shrink-0">
      <span class="text-white font-bold text-xl tracking-tight">TRS <span class="text-[#17A2B8]">Pharmacy</span></span>
    </a>

    <!-- Desktop nav -->
    <nav class="hidden md:flex items-center gap-6 text-sm font-semibold">
      {navLinks.map(link => (
        <a href={link.href} class="text-white/80 hover:text-white transition-colors">{link.label}</a>
      ))}
    </nav>

    <!-- Phone CTA (desktop) -->
    <a href="tel:3462304148" class="hidden md:inline-flex items-center gap-2 bg-[#17A2B8] hover:bg-[#138496] text-white font-semibold px-4 py-2 rounded-lg text-sm transition-colors">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
      </svg>
      346-230-4148
    </a>

    <!-- Mobile hamburger -->
    <button id="menu-btn" class="md:hidden text-white p-2" aria-label="Open menu">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5M3.75 17.25h16.5" />
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-[#0a2444] border-t border-white/10">
    <div class="container-site py-4 flex flex-col gap-3">
      {navLinks.map(link => (
        <a href={link.href} class="text-white/80 hover:text-white font-semibold py-1 transition-colors">{link.label}</a>
      ))}
      <a href="tel:3462304148" class="mt-2 btn-primary justify-center text-center">Call 346-230-4148</a>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
