---
const navLinks = [
  { label: 'Services', href: '/services' },
  { label: 'Insurance', href: '/insurance-accepted' },
  { label: 'Delivery', href: '/services/prescription-delivery' },
  { label: 'About', href: '/about' },
  { label: 'Blog', href: '/blog' },
  { label: 'Contact', href: '/contact' },
];
---

<!-- Sticky wrapper — both bars scroll together -->
<div class="sticky top-0 z-50">

  <!-- Utility bar -->
  <div class="bg-[#28759F] text-white py-2.5 px-4 text-xs font-semibold">
    <div class="max-w-7xl mx-auto flex flex-col sm:flex-row justify-between items-center gap-2">
      <div class="flex items-center gap-4">
        <span class="flex items-center gap-1.5">
          <svg class="w-3.5 h-3.5 text-[#9EC8DC]" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 00-1.414 0L8 12.586 4.707 9.293a1 1 0 00-1.414 1.414l4 4a1 1 0 001.414 0l8-8a1 1 0 000-1.414z" clip-rule="evenodd"/></svg>
          Local 501(c)(3) Nonprofit
        </span>
        <span class="hidden md:flex items-center gap-1.5 text-white/70 uppercase tracking-wider">
          Mon–Sat: 9 AM – 5 PM
        </span>
      </div>
      <a href="tel:3462304148" class="flex items-center gap-1.5 bg-[#F16742] hover:bg-[#D4522E] px-3 py-1 rounded-full text-white font-bold transition-colors duration-200 text-xs">
        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" /></svg>
        346-230-4148
      </a>
    </div>
  </div>

  <!-- Main nav -->
  <header class="glass-panel">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-center h-[68px]">

        <!-- Logo -->
        <a href="/" class="flex items-center shrink-0">
          <img src="/images/trs-logo.png" alt="TRS Pharmacy" class="h-10 w-auto" />
        </a>

        <!-- Desktop nav -->
        <nav class="hidden md:flex items-center gap-7 font-medium text-sm text-[#1E5A78]">
          {navLinks.map(link => (
            <a href={link.href} class="relative group py-1 hover:text-[#F16742] transition-colors">
              {link.label}
              <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-[#F16742] transition-all duration-300 group-hover:w-full rounded-full"></span>
            </a>
          ))}
        </nav>

        <!-- CTA -->
        <a href="/services/prescription-refills" class="hidden md:inline-flex items-center gap-2 bg-[#F16742] hover:bg-[#D4522E] text-white font-semibold px-5 py-2.5 rounded-full text-sm transition-all shadow-[0_4px_14px_0_rgba(241,103,66,0.35)] hover:-translate-y-0.5">
          Refill Now
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" /></svg>
        </a>

        <!-- Mobile hamburger -->
        <button id="menu-btn" class="md:hidden text-[#28759F] p-2" aria-label="Open menu">
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5M3.75 17.25h16.5" />
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile menu -->
    <div id="mobile-menu" class="hidden md:hidden bg-white/95 border-t border-[#DCF0F8]">
      <div class="max-w-7xl mx-auto px-4 py-4 flex flex-col gap-3">
        {navLinks.map(link => (
          <a href={link.href} class="text-[#1E5A78] hover:text-[#F16742] font-semibold py-1.5 transition-colors">{link.label}</a>
        ))}
        <a href="/services/prescription-refills" class="mt-2 btn-primary justify-center text-center text-sm">
          Refill a Prescription
        </a>
      </div>
    </div>
  </header>
</div>

<script>
  const btn = document.getElementById('menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
