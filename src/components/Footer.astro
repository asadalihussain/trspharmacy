---
const services = [
  { label: 'Immunizations', href: '/services/immunizations' },
  { label: 'Diabetes Care', href: '/services/diabetes-care' },
  { label: 'Free Delivery', href: '/services/prescription-delivery' },
  { label: 'Precision Medicine', href: '/services/precision-medicine' },
  { label: 'Nutrient Depletion', href: '/services/nutrient-depletion' },
  { label: 'Point-of-Care Testing', href: '/services/point-of-care-testing' },
  { label: 'Prescription Refills', href: '/services/prescription-refills' },
  { label: 'Health Screenings', href: '/services/health-screenings' },
];

const locations = [
  { label: 'Stafford, TX', href: '/pharmacy-stafford-tx' },
  { label: 'Sugar Land, TX', href: '/pharmacy-sugar-land-tx' },
  { label: 'Missouri City, TX', href: '/pharmacy-missouri-city-tx' },
  { label: 'SW Houston', href: '/pharmacy-southwest-houston-tx' },
  { label: 'Richmond / Rosenberg', href: '/pharmacy-richmond-rosenberg-tx' },
];
---

<footer class="bg-[#0C2535] text-[#9EC8DC] mt-12 rounded-t-[40px] pt-16 pb-8 border-t-4 border-[#28759F]">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Main grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 pb-14 border-b border-[#28759F]">

      <!-- Brand + NAP -->
      <div class="lg:pr-6">
        <div class="flex items-center gap-2.5 mb-5">
          <div class="w-9 h-9 bg-white/10 rounded-xl flex items-center justify-center border border-white/20">
            <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0112 15a9.065 9.065 0 00-6.23-.693L5 14.5m14.8.8 1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0112 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5" />
            </svg>
          </div>
          <div class="flex flex-col">
            <span class="font-heading font-bold text-xl leading-none text-white">TRS Pharmacy</span>
            <span class="text-[0.6rem] font-semibold uppercase tracking-[0.15em] text-[#6AAFC9] mt-0.5">The Rising Sun · 501(c)(3)</span>
          </div>
        </div>
        <address class="not-italic text-sm leading-relaxed mb-4">
          3727 Greenbriar Dr, Suite 114<br>
          Stafford, TX 77477
        </address>
        <div class="flex flex-col gap-1.5 text-sm mb-5">
          <a href="tel:3462304148" class="text-[#F16742] hover:text-white font-bold transition-colors">346-230-4148</a>
          <a href="fax:3462190414" class="text-[#6AAFC9] text-xs hover:text-white transition-colors">Fax: 346-219-0414</a>
          <a href="mailto:info@trspharmacy.org" class="text-[#6AAFC9] text-xs hover:text-white transition-colors">info@trspharmacy.org</a>
        </div>
        <!-- Social -->
        <div class="flex gap-3">
          <a href="https://www.facebook.com/trspharmacy" rel="noopener noreferrer" aria-label="Facebook"
            class="w-9 h-9 rounded-full bg-[#28759F] flex items-center justify-center hover:bg-[#F16742] transition-colors">
            <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
          <a href="https://www.instagram.com/trspharmacy" rel="noopener noreferrer" aria-label="Instagram"
            class="w-9 h-9 rounded-full bg-[#28759F] flex items-center justify-center hover:bg-[#F16742] transition-colors">
            <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
          </a>
        </div>
      </div>

      <!-- Hours -->
      <div>
        <p class="font-heading font-bold text-white text-base mb-5">Hours</p>
        <ul class="text-sm space-y-2">
          <li class="flex justify-between gap-4">
            <span>Monday – Saturday</span>
            <span class="font-semibold text-white">9 AM – 5 PM</span>
          </li>
          <li class="flex justify-between gap-4">
            <span>Sunday</span>
            <span class="font-semibold text-white">Closed</span>
          </li>
        </ul>

        <p class="font-heading font-bold text-white text-base mt-8 mb-5">Areas Served</p>
        <ul class="text-sm space-y-1.5">
          {locations.map(l => (
            <li><a href={l.href} class="hover:text-white transition-colors">{l.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Services -->
      <div>
        <p class="font-heading font-bold text-white text-base mb-5">Clinical Services</p>
        <ul class="text-sm space-y-1.5">
          {services.map(s => (
            <li><a href={s.href} class="hover:text-white transition-colors">{s.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Patients -->
      <div>
        <p class="font-heading font-bold text-white text-base mb-5">Patients</p>
        <ul class="text-sm space-y-1.5">
          <li><a href="/services/prescription-refills" class="hover:text-white transition-colors">Refill Prescription</a></li>
          <li><a href="/services/prescription-refills" class="hover:text-white transition-colors">Transfer to TRS</a></li>
          <li><a href="/services/prescription-delivery" class="hover:text-white transition-colors">Schedule Delivery</a></li>
          <li><a href="/insurance-accepted" class="hover:text-white transition-colors">Insurance Accepted</a></li>
          <li><a href="/self-pay-pharmacy" class="hover:text-white transition-colors">Self-Pay Pricing</a></li>
          <li><a href="/faq" class="hover:text-white transition-colors">FAQ</a></li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-8 flex flex-col md:flex-row justify-between items-center gap-3 text-xs text-[#6AAFC9]">
      <p>&copy; {new Date().getFullYear()} TRS Pharmacy · 501(c)(3) Non-Profit Organization · Stafford, TX</p>
      <div class="flex gap-5">
        <a href="/privacy-policy" class="hover:text-white transition-colors">Privacy Policy</a>
        <a href="/contact" class="hover:text-white transition-colors">Contact</a>
      </div>
    </div>
  </div>
</footer>
